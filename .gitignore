# Ignorăm tot WordPress-ul
/*

# Permitem fișierele necesare pentru deploy (YAML)
!cpanel.yml
!.cpanel.yml
!.gitignore

# Permitem wp-content
!wp-content/

# Ignorăm tot din wp-content
wp-content/*

# Permitem themes și plugins
!wp-content/themes/
!wp-content/plugins/

# Ignorăm toate temele, apoi permitem doar tema child
wp-content/themes/*
!wp-content/themes/martfury-child/

# Ignorăm toate pluginurile, apoi permitem doar pluginurile tale custom
wp-content/plugins/*
!wp-content/plugins/webgsm-b2b-pricing/
!wp-content/plugins/webgsm-checkout-pro/
!wp-content/plugins/webgsm-setup-wizard-v2/
!wp-content/plugins/webgsm-tools/
!wp-content/plugins/webgsm-woo-sync/
!wp-content/plugins/webgsm-site-audit/

# webgsm-checkout-pro: exclude backup, dev artifacts, tests
wp-content/plugins/webgsm-checkout-pro.disabled/
wp-content/plugins/webgsm-checkout-pro/DEBUG-*.md
wp-content/plugins/webgsm-checkout-pro/assets.zip
wp-content/plugins/webgsm-checkout-pro/tests/
wp-content/plugins/webgsm-checkout-pro/**/.DS_Store

# Documentație (în repo pentru deploy / referință)
!docs/
docs/*
!docs/architecture/

# MacOS junk
.DS_Store
**/.DS_Store

# Logs & debug (WordPress) – nu în repo
debug.log
wp-content/debug.log
wp-content/webgsm-perf-audit.log
**/webgsm-perf-audit.log

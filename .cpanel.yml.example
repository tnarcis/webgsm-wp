---
# =============================================================================
# Deploy cPanel (Git Version Control)
# =============================================================================
# În REPO: acest fișier rămâne versionat (.cpanel.yml.example).
# PE SERVER: după clone, copiază-l și setează calea ta:
#   cp .cpanel.yml.example .cpanel.yml
#   nano .cpanel.yml   # înlocuiește DEPLOYPATH cu /home/TU/public_html/wp-content
#
# cPanel citește la deploy fișierul .cpanel.yml din root-ul repository-ului
# configurat în „Git Version Control” (nu din laptop dacă e ignorat la push).
# =============================================================================
deployment:
  tasks:
    - export DEPLOYPATH=/home/CHANGE_ME/public_html/wp-content

    - /bin/mkdir -p $DEPLOYPATH/themes
    - /bin/mkdir -p $DEPLOYPATH/plugins

    - /bin/cp -Rf wp-content/themes/martfury-child $DEPLOYPATH/themes/
    - /bin/cp -Rf wp-content/plugins/webgsm-b2b-pricing $DEPLOYPATH/plugins/
    # webgsm-checkout-pro: exclude tests, dev artifacts, .DS_Store
    - /bin/mkdir -p $DEPLOYPATH/plugins/webgsm-checkout-pro
    - rsync -a --exclude='tests' --exclude='DEBUG-*.md' --exclude='assets.zip' --exclude='.DS_Store' wp-content/plugins/webgsm-checkout-pro/ $DEPLOYPATH/plugins/webgsm-checkout-pro/ 2>/dev/null || /bin/cp -Rf wp-content/plugins/webgsm-checkout-pro/* $DEPLOYPATH/plugins/webgsm-checkout-pro/
    - /bin/cp -Rf wp-content/plugins/webgsm-setup-wizard-v2 $DEPLOYPATH/plugins/
    - /bin/cp -Rf wp-content/plugins/webgsm-woo-sync $DEPLOYPATH/plugins/
    - /bin/cp -Rf wp-content/plugins/webgsm-site-audit $DEPLOYPATH/plugins/
    # webgsm-tools: exclude data/ și *.md (doar în repo, nu pe site)
    - /bin/mkdir -p $DEPLOYPATH/plugins/webgsm-tools
    - rsync -a --exclude='*.md' --exclude='data' wp-content/plugins/webgsm-tools/ $DEPLOYPATH/plugins/webgsm-tools/ 2>/dev/null || /bin/cp -Rf wp-content/plugins/webgsm-tools/* $DEPLOYPATH/plugins/webgsm-tools/

    - /bin/chmod -R 755 $DEPLOYPATH/themes/martfury-child
    - /bin/chmod -R 755 $DEPLOYPATH/plugins/webgsm-b2b-pricing
    - /bin/chmod -R 755 $DEPLOYPATH/plugins/webgsm-checkout-pro
    - /bin/chmod -R 755 $DEPLOYPATH/plugins/webgsm-setup-wizard-v2
    - /bin/chmod -R 755 $DEPLOYPATH/plugins/webgsm-woo-sync
    - /bin/chmod -R 755 $DEPLOYPATH/plugins/webgsm-tools
    - /bin/chmod -R 755 $DEPLOYPATH/plugins/webgsm-site-audit
